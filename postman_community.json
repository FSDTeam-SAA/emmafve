{
	"info": {
		"_postman_id": "community-module-hesteka",
		"name": "Hesteka — Community Module",
		"description": "Complete API collection for the Community module (Posts, Likes, Local Chat).\n\n## Setup\n1. Set `base_url` variable (default: `http://localhost:5000/api/v1`)\n2. Run the **Login** request first — it auto-saves the token\n3. All authenticated requests use `{{token}}` automatically",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:5000/api/v1"
		},
		{
			"key": "token",
			"value": ""
		},
		{
			"key": "post_id",
			"value": ""
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Auth",
			"description": "Login first to get a token. The script auto-saves it.",
			"item": [
				{
					"name": "Login (get token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.data && res.data.accessToken) {",
									"    pm.collectionVariables.set('token', res.data.accessToken);",
									"    console.log('Token saved!');",
									"}",
									"if (res.data && res.data.token) {",
									"    pm.collectionVariables.set('token', res.data.token);",
									"    console.log('Token saved!');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"your-email@example.com\",\n    \"password\": \"your-password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": ["{{base_url}}"],
							"path": ["auth", "login"]
						}
					}
				}
			]
		},
		{
			"name": "Posts",
			"description": "CRUD operations for community posts.",
			"item": [
				{
					"name": "Create Post (with images)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.data && res.data._id) {",
									"    pm.collectionVariables.set('post_id', res.data._id);",
									"    console.log('post_id saved:', res.data._id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "content",
									"value": "Un chat perdu trouvé près du parc 🐱",
									"type": "text"
								},
								{
									"key": "location",
									"value": "{\"type\":\"Point\",\"coordinates\":[2.3522,48.8566]}",
									"type": "text"
								},
								{
									"key": "media",
									"type": "file",
									"src": [],
									"description": "Attach up to 5 images (JPEG/PNG/WEBP, max 5MB each)"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/community/posts",
							"host": ["{{base_url}}"],
							"path": ["community", "posts"]
						}
					}
				},
				{
					"name": "Create Post (text only)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.data && res.data._id) {",
									"    pm.collectionVariables.set('post_id', res.data._id);",
									"    console.log('post_id saved:', res.data._id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"content\": \"Quelqu'un a vu ce chien errant dans le 15e arrondissement?\",\n    \"location\": {\n        \"type\": \"Point\",\n        \"coordinates\": [2.3522, 48.8566]\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/community/posts",
							"host": ["{{base_url}}"],
							"path": ["community", "posts"]
						}
					}
				},
				{
					"name": "Global Feed",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/community/posts/global?page=1&limit=10",
							"host": ["{{base_url}}"],
							"path": ["community", "posts", "global"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "10" }
							]
						}
					}
				},
				{
					"name": "Local Feed (Paris)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/community/posts/feed/local?lng=2.3522&lat=48.8566&page=1&limit=10",
							"host": ["{{base_url}}"],
							"path": ["community", "posts", "feed", "local"],
							"query": [
								{ "key": "lng", "value": "2.3522" },
								{ "key": "lat", "value": "48.8566" },
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "10" }
							]
						}
					}
				},
				{
					"name": "Get Single Post",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/community/posts/{{post_id}}",
							"host": ["{{base_url}}"],
							"path": ["community", "posts", "{{post_id}}"]
						}
					}
				},
				{
					"name": "Update Post",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"content\": \"Mise à jour: le chat a été retrouvé! Merci à tous!\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/community/posts/{{post_id}}",
							"host": ["{{base_url}}"],
							"path": ["community", "posts", "{{post_id}}"]
						}
					}
				},
				{
					"name": "Delete Post",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/community/posts/{{post_id}}",
							"host": ["{{base_url}}"],
							"path": ["community", "posts", "{{post_id}}"]
						}
					}
				}
			]
		},
		{
			"name": "Likes",
			"description": "Toggle like/unlike and list likers.",
			"item": [
				{
					"name": "Toggle Like",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/community/posts/{{post_id}}/like",
							"host": ["{{base_url}}"],
							"path": ["community", "posts", "{{post_id}}", "like"]
						}
					}
				},
				{
					"name": "Get Likers",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/community/posts/{{post_id}}/likes?page=1&limit=10",
							"host": ["{{base_url}}"],
							"path": ["community", "posts", "{{post_id}}", "likes"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "10" }
							]
						}
					}
				}
			]
		},
		{
			"name": "Local Chat",
			"description": "REST endpoints for local chat. For real-time, use Socket.IO.",
			"item": [
				{
					"name": "Send Message (REST)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"message\": \"Bonjour! Est-ce que quelqu'un a vu un chat gris près de la gare?\",\n    \"location\": {\n        \"type\": \"Point\",\n        \"coordinates\": [2.3522, 48.8566]\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/community/chat/local",
							"host": ["{{base_url}}"],
							"path": ["community", "chat", "local"]
						}
					}
				},
				{
					"name": "Get Chat History (Paris)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/community/chat/local?lng=2.3522&lat=48.8566&page=1&limit=20",
							"host": ["{{base_url}}"],
							"path": ["community", "chat", "local"],
							"query": [
								{ "key": "lng", "value": "2.3522" },
								{ "key": "lat", "value": "48.8566" },
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "20" }
							]
						}
					}
				},
				{
					"name": "Get Chat History (Lyon — should be empty)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/community/chat/local?lng=4.8357&lat=45.7640&page=1&limit=20",
							"host": ["{{base_url}}"],
							"path": ["community", "chat", "local"],
							"query": [
								{ "key": "lng", "value": "4.8357" },
								{ "key": "lat", "value": "45.7640" },
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "20" }
							]
						}
					}
				}
			]
		}
	]
}
